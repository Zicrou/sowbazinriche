<div class="m-5">
  <p style="color: green"><%= notice %></p>

  <h1>Produits</h1>

  <div id="produits">
    <% @produits.each do |produit| %>
      <%= render produit %>
      <p>
        <%= link_to "Show this produit", produit %>
      </p>
    <% end %>
  </div>

  <%= link_to "Ajouter un produit", new_produit_path %>
</div>