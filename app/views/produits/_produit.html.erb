<div id="<%= dom_id produit %>">
  <p>
    <strong>Name:</strong>
    <%= produit.name %>
  </p>

  <p>
    <strong>Price:</strong>
    <%= produit.price %>
  </p>

  <p>
    <strong>Quantity:</strong>
    <%= produit.quantity %>
  </p>

  <p>
    <strong>Stock:</strong>
    <%= produit.stock %>
  </p>

  <p>
    <strong>Category:</strong>
    <%= produit.category_id %>
  </p>

</div>
