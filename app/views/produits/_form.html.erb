<div class="" >
  <%= form_with(model: produit) do |form| %>
    <% if produit.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(produit.errors.count, "error") %> prohibited this produit from being saved:</h2>

        <ul>
          <% produit.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :name, style: "display: block" %>
      <%= form.text_field :name, class:"form-control text-dark" %>
    </div>

    <div class="form-group">
      <%= form.label :price, style: "display: block" %>
      <%= form.number_field :price, class:"form-control text-dark" %>
    </div>

    <div class="form-group">
      <%= form.label :quantity, style: "display: block" %>
      <%= form.number_field :quantity, class:"form-control text-dark" %>
    </div>

    <div class="form-group">
      <%= form.label :stock, style: "display: block" %>
      <%= form.number_field :stock, class:"form-control text-dark" %>
    </div>

    <div class="form-group">
      <%= form.label :category_id, style: "display: block" %>
      <%= form.text_field :category_id, class:"form-control text-dark" %>
    </div>
<br/>
    <div class="form-group">
      <%= form.submit class:"btn btn-outline-warning text-dark" %>
    </div>
  <% end %>
</div>